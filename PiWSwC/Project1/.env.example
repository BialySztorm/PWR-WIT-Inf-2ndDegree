# Docker Compose (root)
COMPOSE_PROJECT_NAME=pwr

# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.bylena3.cloud

# Database (docker)
DB_HOST=db
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app

# Frontend (Vite build-time)
VITE_API_BASE=http://localhost:8000